import streamlit as st
import os
import re
import zipfile
from pydub import AudioSegment
from mutagen.id3 import ID3, TIT2, TALB, TRCK, TPE1, APIC
import yt_dlp
import io

# --- CONFIGURACIÓN DE PÁGINA ---
st.set_page_config(page_title="Segmentador de Audio Pro", page_icon="🎵")

st.title("🎵 Segmentador de Audio & Metadata")
st.markdown("Extrae audio de links o sube archivos locales, segmenta y añade metadata de álbum.")

# --- DATOS POR DEFECTO (IMAGEN) ---
DEFAULT_TIMES = "00:00, 01:48, 05:46, 08:55, 12:59, 16:19, 19:20, 23:39, 28:23, 32:18, 36:38, 41:55, 45:23"
DEFAULT_NAMES = "Matamoros Rag, Lo que te voy a contar, Amar a Martha era mi tarea, Alma de tabique, Castillos de arena, Ay qué dolor vivir, Un curso intensivo, Castillos en el viento, Mano de mando, Doroteo, Olores de óleo, Oficio sin beneficio, Luisiana lulabi"

def timestamp_to_ms(ts):
    parts = list(map(int, ts.split(':')))
    if len(parts) == 3: return (parts[0] * 3600 + parts[1] * 60 + parts[2]) * 1000
    elif len(parts) == 2: return (parts[0] * 60 + parts[1]) * 1000
    else: return parts[0] * 1000

# --- SIDEBAR: CONFIGURACIÓN DE METADATA ---
st.sidebar.header("Configuración del Álbum")
album_name = st.sidebar.text_input("Nombre del Álbum", "Mi Álbum")
artist_name = st.sidebar.text_input("Artista", "Artista Desconocido")
cover_image = st.sidebar.file_uploader("Portada del Álbum (JPG/PNG)", type=["jpg", "jpeg", "png"])

# --- PANEL PRINCIPAL: ENTRADA DE DATOS ---
tab1, tab2 = st.tabs(["Fuentes de Audio", "Lista de Pistas"])

with tab1:
    source_option = st.radio("Origen del audio:", ["Link (YouTube, etc.)", "Subir archivo local"])
    audio_file_path = None
    
    if source_option == "Link (YouTube, etc.)":
        url = st.text_input("Pega el enlace aquí:")
        if url:
            if st.button("Descargar Audio"):
                with st.spinner("Descargando..."):
                    ydl_opts = {
                        'format': 'bestaudio/best',
                        'postprocessors': [{'key': 'FFmpegExtractAudio', 'preferredcodec': 'mp3', 'preferredquality': '192'}],
                        'outtmpl': 'audio_temp.%(ext)s',
                    }
                    try:
                        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                            ydl.download([url])
                        audio_file_path = "audio_temp.mp3"
                        st.success("Descarga completada.")
                    except Exception as e:
                        st.error(f"Error en descarga: {e}")
    else:
        uploaded_audio = st.file_uploader("Sube tu MP3", type=["mp3"])
        if uploaded_audio:
            with open("audio_temp.mp3", "wb") as f:
                f.write(uploaded_audio.getbuffer())
            audio_file_path = "audio_temp.mp3"

with tab2:
    st.info("Copia y pega las listas separadas por comas.")
    times_input = st.text_area("Tiempos de inicio:", value=DEFAULT_TIMES)
    names_input = st.text_area("Nombres de canciones:", value=DEFAULT_NAMES)

# --- PROCESAMIENTO ---
if st.button("🚀 Iniciar Segmentación", type="primary"):
    if not os.path.exists("audio_temp.mp3"):
        st.error("No hay archivo de audio para procesar.")
    else:
        timestamps = [ts.strip() for ts in times_input.split(',')]
        song_names = [name.strip() for name in names_input.split(',')]
        
        if len(timestamps) != len(song_names):
            st.error("La cantidad de tiempos y nombres no coincide.")
        else:
            audio = AudioSegment.from_file("audio_temp.mp3")
            duration_ms = len(audio)
            output_dir = "final_album"
            if not os.path.exists(output_dir): os.makedirs(output_dir)
            
            progress_bar = st.progress(0)
            
            for i, (ts, name) in enumerate(zip(timestamps, song_names)):
                start_ms = timestamp_to_ms(ts)
                end_ms = timestamp_to_ms(timestamps[i+1]) if i + 1 < len(timestamps) else duration_ms
                
                segment = audio[start_ms:end_ms]
                safe_name = re.sub(r'[^\w\s-]', '', name).strip()
                export_path = f"{output_dir}/{i+1:02d} - {safe_name}.mp3"
                
                segment.export(export_path, format="mp3", bitrate="192k")
                
                # Metadata
                try:
                    tag = ID3(export_path)
                    tag.add(TIT2(encoding=3, text=name))
                    tag.add(TALB(encoding=3, text=album_name))
                    tag.add(TPE1(encoding=3, text=artist_name))
                    tag.add(TRCK(encoding=3, text=str(i+1)))
                    if cover_image:
                        tag.add(APIC(encoding=3, mime=cover_image.type, type=3, desc='Cover', data=cover_image.getvalue()))
                    tag.save()
                except: pass
                
                progress_bar.progress((i + 1) / len(timestamps))
            
            # Comprimir
            zip_buffer = io.BytesIO()
            with zipfile.ZipFile(zip_buffer, "w") as zf:
                for root, dirs, files in os.walk(output_dir):
                    for file in files:
                        zf.write(os.path.join(root, file), file)
            
            st.success("¡Segmentación terminada!")
            st.download_button(
                label="📥 Descargar Álbum Completo (.zip)",
                data=zip_buffer.getvalue(),
                file_name=f"{album_name}.zip",
                mime="application/zip"
            )
